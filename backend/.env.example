PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173
MAX_FILE_SIZE_MB=50
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
GROQ_API_KEY=your_groq_api_key_here

# ── Clerk Auth ─────────────────────
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxx

# ── Database (Supabase + Prisma) ───
# Not needed for dummy data mode, but required for production
DATABASE_URL=postgresql://postgres:password@db.xxxx.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres

# ── AI Service ─────────────────────
AI_SERVICE_BASE_URL=http://localhost:8000

# ── Twilio (SMS + WhatsApp) ────────
TWILIO_ACCOUNT_SID=ACxxxxx
TWILIO_AUTH_TOKEN=your_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── SMTP (Email) ───────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yourmail@gmail.com
SMTP_PASS=your_app_password

# ── External Blood Bank API (not needed for dummy data mode) ────
EXTERNAL_BLOODBANK_API_URL=
EXTERNAL_BLOODBANK_API_KEY=
